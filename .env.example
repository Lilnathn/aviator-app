################################################################################
# Aviator Betting Application - Environment Configuration
# 
# Copy this file to .env and update the values for your deployment.
# For Render deployment, most of these are set automatically.
# See README.md for detailed instructions.
################################################################################

# ============================================================================
# Application Environment
# ============================================================================
FLASK_ENV=production                    # production or development
FLASK_DEBUG=False                       # Set to False in production
SECRET_KEY=your-very-secure-secret-key-change-this  # Generate a strong key!
JWT_SECRET=change-this-secret-key       # JWT signing key (same as SECRET_KEY recommended)
JWT_ALGORITHM=HS256                     # JWT algorithm
JWT_EXPIRATION_HOURS=24                 # JWT token expiration

# ============================================================================
# Database Configuration
# Render provides DATABASE_URL automatically for PostgreSQL
# For local development, use SQLite (default)
# ============================================================================

# FOR RENDER DEPLOYMENT:
# Leave DATABASE_URL commented - Render adds it automatically
# DATABASE_URL=postgresql://user:password@host:port/dbname

# FOR LOCAL DEVELOPMENT:
# Uncomment one of the following:
# SQLALCHEMY_DATABASE_URI=sqlite:///aviator_demo.db       # SQLite (recommended for dev)
# DATABASE_URL=sqlite:///aviator_demo.db                  # Alternative SQLite syntax

# For PostgreSQL (if using locally):
# DATABASE_URL=postgresql://user:password@localhost:5432/aviator

# ============================================================================
# Server Configuration
# ============================================================================
HOST=0.0.0.0                            # Bind to all interfaces
PORT=5000                               # Port (Render will set PORT env var)

# ============================================================================
# Payment Provider API Keys (Simulated in demo mode)
# Replace with real API keys for production
# ============================================================================

# M-Pesa Daraja (Kenya)
MPESA_API_KEY=your_mpesa_api_key
MPESA_API_SECRET=your_mpesa_api_secret
MPESA_BUSINESS_SHORTCODE=your_shortcode
MPESA_PASS_KEY=your_pass_key

# MTN API (Uganda, Rwanda, Zambia, etc.)
MTN_API_KEY=your_mtn_api_key
MTN_API_USER=your_mtn_api_user
MTN_TARGET_ENVIRONMENT=sandbox          # sandbox or production

# Airtel Money (Tanzania, Uganda, Rwanda, Zambia)
AIRTEL_MERCHANT_CODE=your_merchant_code
AIRTEL_CONSUMER_KEY=your_consumer_key
AIRTEL_CONSUMER_SECRET=your_consumer_secret

# Tigo Pesa (Tanzania)
TIGO_API_CREDENTIALS=your_credentials

# ============================================================================
# Payment Webhook Configuration
# ============================================================================
PAYMENT_WEBHOOK_SECRET=your_webhook_secret

# FOR RENDER:
PAYMENT_SUCCESS_URL=https://your-app.onrender.com/payment/success
PAYMENT_FAILURE_URL=https://your-app.onrender.com/payment/failure

# FOR LOCAL:
# PAYMENT_SUCCESS_URL=http://localhost:5000/payment/success
# PAYMENT_FAILURE_URL=http://localhost:5000/payment/failure

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO                          # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FILE=aviator.log                    # Log file location

# ============================================================================
# CORS Configuration
# ============================================================================
# Comma-separated list of allowed origins (for Render)
CORS_ORIGINS=https://your-app.onrender.com,http://localhost:3000,http://localhost:5000

# ============================================================================
# Render-Specific Configuration
# These are typically set automatically by Render
# ============================================================================
# RENDER = true              # Set automatically by Render
# RENDER_EXTERNAL_URL = https://your-app.onrender.com
# DATABASE_URL = postgresql://...  # Automatically provided by Render

# Email (for notifications, future feature)
EMAIL_PROVIDER=smtp
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email
SMTP_PASSWORD=your_password
ADMIN_EMAIL=admin@aviator-demo.local

# Sentry (Error Tracking, optional)
SENTRY_DSN=

# Feature Flags
ENABLE_REAL_PAYMENTS=False  # Set to True when ready for production
ENABLE_EMAIL_NOTIFICATIONS=False
ENABLE_WEBHOOK_VERIFICATION=True

# Game Configuration
GAME_MIN_BET=1.0
GAME_MAX_BET=10000.0
GAME_MIN_CRASH_POINT=1.0
GAME_MAX_CRASH_POINT=500.0

# Wallet Configuration
WALLET_MIN_DEPOSIT=1.0
WALLET_MAX_DEPOSIT=100000.0
WALLET_INITIAL_BALANCE=100.0
