"""
Environment Configuration Template
Copy this to .env and fill in your values for production
"""

# Flask Configuration
FLASK_ENV=development  # production or development
FLASK_DEBUG=False
SECRET_KEY=your-very-secure-secret-key-change-this

# Database
SQLALCHEMY_DATABASE_URI=sqlite:///aviator_demo.db
DATABASE_URL=sqlite:///aviator_demo.db

# Server
HOST=0.0.0.0
PORT=5000

# JWT Configuration
JWT_SECRET=change-this-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# M-Pesa Daraja (Kenya)
MPESA_API_KEY=your_mpesa_api_key
MPESA_API_SECRET=your_mpesa_api_secret
MPESA_BUSINESS_SHORTCODE=your_shortcode
MPESA_PASS_KEY=your_pass_key

# MTN API
MTN_API_KEY=your_mtn_api_key
MTN_API_USER=your_mtn_api_user
MTN_TARGET_ENVIRONMENT=sandbox  # or production

# Airtel Money
AIRTEL_MERCHANT_CODE=your_merchant_code
AIRTEL_CONSUMER_KEY=your_consumer_key
AIRTEL_CONSUMER_SECRET=your_consumer_secret

# Tigo Pesa
TIGO_API_CREDENTIALS=your_credentials

# Payment Configuration
PAYMENT_WEBHOOK_SECRET=your_webhook_secret
PAYMENT_SUCCESS_URL=http://localhost:5000/payment/success
PAYMENT_FAILURE_URL=http://localhost:5000/payment/failure

# Logging
LOG_LEVEL=INFO
LOG_FILE=aviator.log

# Email (for notifications, future feature)
EMAIL_PROVIDER=smtp
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email
SMTP_PASSWORD=your_password
ADMIN_EMAIL=admin@aviator-demo.local

# Sentry (Error Tracking, optional)
SENTRY_DSN=

# Feature Flags
ENABLE_REAL_PAYMENTS=False  # Set to True when ready for production
ENABLE_EMAIL_NOTIFICATIONS=False
ENABLE_WEBHOOK_VERIFICATION=True

# Game Configuration
GAME_MIN_BET=1.0
GAME_MAX_BET=10000.0
GAME_MIN_CRASH_POINT=1.0
GAME_MAX_CRASH_POINT=500.0

# Wallet Configuration
WALLET_MIN_DEPOSIT=1.0
WALLET_MAX_DEPOSIT=100000.0
WALLET_INITIAL_BALANCE=100.0
